# Terraform local files
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json

# Keep the lock file committed
!.terraform.lock.hcl

# Environment and secrets
.env
.env.*
*.pem
*.key
*.crt
id_rsa
id_rsa.pub

# Local AWS files
.aws/
credentials
config

# OS/editor files
.DS_Store
.vscode/

# Screenshots that may expose account details
screenshots/private/
*.heic
